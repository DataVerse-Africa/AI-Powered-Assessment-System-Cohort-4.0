# ══════════════════════════════════════════════════════════════════════
#  Patient Assessment System — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it is already in .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── JWT Secret ────────────────────────────────────────────────────────
# Change this to any long random string before going live.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# ── Token Expiry (minutes) ────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────
# SQLite (development — no setup needed, file created automatically)
DATABASE_URL=sqlite:///./patient_assessment.db

# PostgreSQL (production — uncomment and fill in when ready)
# DATABASE_URL=postgresql://username:password@localhost:5432/patient_assessment_db

# ── Admin Credentials ─────────────────────────────────────────────────
# These are the login details for the admin panel.
# You set them here — they are never stored in the database.
ADMIN_EMAIL=admin@clinic.com
ADMIN_PASSWORD=change-this-admin-password

# ── Admin JWT Secret (separate from patient JWT) ───────────────────────
# Keeps admin tokens completely isolated from patient tokens.
ADMIN_SECRET_KEY=change-this-to-a-different-admin-secret
